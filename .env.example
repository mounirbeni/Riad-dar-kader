# --- Database ---
# Pooled PostgreSQL connection string used by the app at runtime.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/riad_dar_kader?schema=public"
# Direct (unpooled) connection used for migrations / `prisma db push`.
# On Neon, this is the host WITHOUT "-pooler". Locally it can equal DATABASE_URL.
DIRECT_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/riad_dar_kader?schema=public"

# Secret protecting the one-time DB bootstrap route (GET /api/seed?secret=...)
SEED_SECRET="change-me-to-a-random-string"

# --- Auth ---
# Secret used to sign admin session JWTs. Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string"

# Default admin seed account (used by prisma/seed.ts)
ADMIN_EMAIL="owner@mbndemo.com"
ADMIN_PASSWORD="Owner@1234"

# --- Riad contact / WhatsApp ---
# International format without "+" or spaces, e.g. 212600000000
NEXT_PUBLIC_WHATSAPP_NUMBER="212600000000"
NEXT_PUBLIC_CONTACT_EMAIL="contact@riaddarkader.com"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Email (optional, choose one provider) ---
# Provider: "resend" | "brevo" | "" (console-only in dev)
EMAIL_PROVIDER=""
EMAIL_FROM="Riad Dar Kader <reservations@riaddarkader.com>"
# Resend
RESEND_API_KEY=""
# Brevo
BREVO_API_KEY=""
# Where owner notifications are sent
OWNER_NOTIFICATION_EMAIL="owner@riaddarkader.com"
