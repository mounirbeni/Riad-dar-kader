// Riad Dar Kader — Prisma schema
// PostgreSQL data model for the custom booking platform.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BookingStatus {
  pending
  confirmed
  cancelled
  completed
}

enum ExtraPriceType {
  per_booking
  per_guest
  per_night
}

enum AdminRole {
  owner
  manager
}

model Room {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  description   String // primary (French)
  descriptionEn String? // optional English description
  capacity      Int      @default(2)
  basePrice     Int // stored in EUR (whole euros) per night
  sizeM2        Int? // room size in square metres
  bedType       String? // key: double | twin | double_sofa | family
  view          String? // key: patio | terrace | medina
  amenities     String[] @default([]) // amenity keys, e.g. wifi, ac, ensuite
  isActive      Boolean  @default(true)
  photos        String[] @default([])
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  bookingRooms BookingRoom[]
  blockedDates BlockedDate[]

  @@index([isActive])
}

model Booking {
  id              String        @id @default(cuid())
  reference       String        @unique // human-friendly e.g. DK-7F3A9
  checkIn         DateTime      @db.Date
  checkOut        DateTime      @db.Date
  guests          Int
  guestName       String
  guestEmail      String
  guestPhone      String
  guestCountry    String?
  specialRequests String?
  status          BookingStatus @default(pending)
  checkedIn       Boolean       @default(false) // guest has physically arrived
  optionLabel     String? // e.g. "Family Stay", "Full Riad Request"
  estimatedTotal  Int           @default(0) // EUR
  adminNotes      String?
  guestUserId     String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  rooms         BookingRoom[]
  extras        BookingExtra[]
  guestUser     GuestUser?           @relation(fields: [guestUserId], references: [id], onDelete: SetNull)
  messages      BookingMessage[]
  statusHistory BookingStatusHistory[]
  emailLogs     EmailLog[]

  @@index([status])
  @@index([checkIn, checkOut])
  @@index([guestUserId])
}

model BookingRoom {
  id        String  @id @default(cuid())
  bookingId String
  roomId    String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  room      Room    @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([bookingId, roomId])
  @@index([roomId])
}

model Extra {
  id          String         @id @default(cuid())
  slug        String         @unique
  name        String
  nameFr      String
  description String
  descriptionFr String
  price       Int // EUR
  priceType   ExtraPriceType @default(per_booking)
  isActive    Boolean        @default(true)
  sortOrder   Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  bookingExtras BookingExtra[]

  @@index([isActive])
}

model BookingExtra {
  id            String  @id @default(cuid())
  bookingId     String
  extraId       String
  quantity      Int     @default(1)
  priceSnapshot Int // EUR captured at request time
  nameSnapshot  String
  booking       Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  extra         Extra   @relation(fields: [extraId], references: [id], onDelete: Cascade)

  @@index([bookingId])
}

model BlockedDate {
  id        String   @id @default(cuid())
  roomId    String? // null = whole riad blocked for that date
  date      DateTime @db.Date
  reason    String?
  createdAt DateTime @default(now())

  room Room? @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, date])
  @@index([date])
}

model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String?
  role         AdminRole @default(owner)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model GuestUser {
  id               String    @id @default(cuid())
  email            String    @unique
  passwordHash     String
  name             String
  phone            String?   @unique
  country          String?
  resetToken       String?   // hashed reset token
  resetTokenExpiry DateTime? // token expiry (1 hour from request)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  bookings     Booking[]

  @@index([email])
}

model ContactMessage {
  id        String   @id @default(cuid())
  from      String
  email     String
  subject   String
  body      String
  channel   String   @default("form") // form | email | whatsapp
  status    String   @default("new")  // new | read | replied
  reply     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

model ScheduleEntry {
  id          String   @id @default(cuid())
  date        DateTime @db.Date
  time        String   // "09:00"
  title       String
  description String?
  location    String?
  assignee    String?
  category    String   @default("general") // arrival | departure | housekeeping | service | meal | general
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
}

model BookingMessage {
  id         String   @id @default(cuid())
  bookingId  String
  sender     String   // "admin" | "guest"
  senderName String
  content    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([createdAt])
}

model BookingStatusHistory {
  id         String        @id @default(cuid())
  bookingId  String
  fromStatus BookingStatus?
  toStatus   BookingStatus
  note       String?
  createdAt  DateTime      @default(now())

  booking    Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([createdAt])
}

model EmailLog {
  id        String   @id @default(cuid())
  bookingId String?
  to        String
  subject   String
  template  String   @default("unknown")
  status    String   @default("sent")  // sent | failed
  error     String?
  createdAt DateTime @default(now())

  booking   Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([bookingId])
  @@index([createdAt])
}

model SurveyResponse {
  id             String   @id @default(cuid())
  // Section 1
  riadName       String
  city           String
  roomCount      String
  yearsOpen      String
  // Section 2
  bookingMethods String[]
  hasWebsite     String
  platforms      String[]
  directPct      String
  occupancyRate  String
  // Section 3
  challenges     String[]
  adminTimeDay   String
  lostBookings   String
  biggestStress  String
  // Section 4
  wantedFeatures String[]
  techComfort    String
  wantsArabic    String
  usesSmartphone String
  // Section 5
  currentlyPays  String
  currentAmount  String?
  willingToPay   String
  payPreference  String
  commissionOk   String
  // Section 6
  wantsDemo      Boolean  @default(false)
  contactName    String?
  contactWa      String?
  comments       String?
  locale         String   @default("fr")
  createdAt      DateTime @default(now())

  @@index([createdAt])
}

model HousekeepingTask {
  id        String   @id @default(cuid())
  roomName  String
  task      String
  priority  String   @default("normal") // urgent | normal | low
  status    String   @default("pending") // pending | in_progress | done
  assignee  String?
  dueDate   DateTime @db.Date
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dueDate])
  @@index([status])
}
